COMPOSE_PROJECT_NAME=holdfast

# Image and deployment
HOLDFAST_IMAGE=holdfast-server-local:latest
ENABLE_ADMIN_STACK=false
ADMIN_BIND_ADDRESS=127.0.0.1
ADMIN_HOSTNAME=holdfast-admin.local

# Holdfast server identity
SERVER_NAME=[EU] 42nd Regiment Linebattle
SERVER_WELCOME_MESSAGE=Bienvenue sur le serveur regimentaire Holdfast.
SERVER_INTRO_TITLE=42nd Regiment
SERVER_INTRO_BODY=Serveur linebattle prive pour tests LAN et repetition.
SERVER_REGION=europe
SERVER_PASSWORD=
SERVER_ADMIN_PASSWORD=change-me-now
SERVER_DESCRIPTION=Serveur Holdfast linebattle pour tests locaux et entrainement regimentaire.
NETWORK_BROADCAST_MODE=Standard
FRAMERATE=120
FRIENDLY_FIRE=false
FRIENDLY_FIRE_MELEE_BOUNCE=false
DAMAGE_SPLIT=0
SHOW_SERVERPERFORMANCE_WARNING=true
MAP_ROTATION_START_RANDOMISE=false
POPULATION_LOW_MIN_PLAYERS=20
POPULATION_MEDIUM_MIN_PLAYERS=50
POPULATION_HIGH_MIN_PLAYERS=100
SPAWN_IMMUNITY_TIMER=3
WAVE_SPAWN_TIME_SECONDS=10
WAVE_SPAWN_VEHICLE_TIME_SECONDS=20
WAVE_SPAWN_DYNAMIC_TIME_SECONDS=15
ROUND_TIME_MINUTES=15
ALLOW_MIDROUND_SPAWNING=false
ALLOW_FACTION_SWITCHING=false
ALLOW_SPECTATING=true
FACTION_BALANCING=true
FACTION_BALANCING_DISCREPANCY_AMOUNT=1
MAXIMUM_PLAYERS=120
MINIMUM_PLAYERS=0

# Network
SERVER_PORT=20100
STEAM_COMMUNICATIONS_PORT=8700
STEAM_QUERY_PORT=27000

# Runtime
STEAMCMD_VALIDATE=false
TZ=America/Toronto
PUID=1000
PGID=1000

# Optional admin stack (Traefik + oauth2-proxy + Keycloak)
OIDC_COOKIE_SECRET=replace-with-32-byte-base64
OIDC_CLIENT_ID=holdfast-admin
OIDC_CLIENT_SECRET=replace-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-now
